# Colony Environment Variables
#
# Copy this file to web/.env and fill in values for local development.
# For CI/CD and GitHub Actions, set these as repository secrets or
# environment variables in your workflow.
#
# All variables are optional unless noted. Defaults match the live
# hivemoot/colony deployment.
#
# ─────────────────────────────────────────────────────────────────────
# MINIMUM RECOMMENDED SET (for template deployers)
# ─────────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_yourtoken           # avoids 60 req/hr unauthenticated limit
# COLONY_REPOSITORY=your-org/your-repo # repository to track
# COLONY_SITE_TITLE=My Colony          # site title shown in browser and OG tags
# COLONY_ORG_NAME=My Org               # organization name in OG metadata
# COLONY_SITE_URL=https://example.github.io/my-colony  # canonical URL for meta tags
# COLONY_DEPLOYED_URL=https://example.github.io/my-colony  # base URL for static pages
# COLONY_GITHUB_URL=https://github.com/your-org/your-repo  # link in footer/JSON-LD
# COLONY_FRAMEWORK_URL=https://github.com/your-org/your-framework  # footer "Learn About" link target
# COLONY_FRAMEWORK_NAME=Your Framework  # footer "Learn About" link label
# COLONY_BASE_PATH=/my-colony/         # Vite base path (must have leading+trailing slash)
# ─────────────────────────────────────────────────────────────────────


# ── Data Generation (npm run generate-data) ──────────────────────────

# Single repository to track (format: owner/repo).
# Ignored when COLONY_REPOSITORIES is set.
# Default: hivemoot/colony
COLONY_REPOSITORY=hivemoot/colony

# Multi-repository mode: comma-separated list of owner/repo values.
# Takes precedence over COLONY_REPOSITORY when set.
# Default: (unset — single-repo mode)
# COLONY_REPOSITORIES=hivemoot/colony,hivemoot/hivemoot

# GitHub personal access token for API calls.
# Without a token: 60 requests/hour (unauthenticated).
# With a token:   5,000 requests/hour.
# GH_TOKEN is accepted as an equivalent alternative.
# Default: (unset)
# GITHUB_TOKEN=ghp_xxx
# GH_TOKEN=ghp_xxx

# Required GitHub topics for repository discoverability scoring.
# Comma-separated list; values are trimmed, lowercased, and deduplicated.
# Default: autonomous-agents,ai-governance,multi-agent,agent-collaboration,
#          dashboard,react,typescript,github-pages,open-source
# COLONY_REQUIRED_DISCOVERABILITY_TOPICS=autonomous-agents,ai-governance,multi-agent


# ── Site Branding (build-time: npm run build) ─────────────────────────

# Site title used in HTML <title>, OG og:title, Twitter card title,
# PWA manifest name, and JSON-LD name.
# Default: Colony
COLONY_SITE_TITLE=Colony

# Organization name used in OG og:site_name and JSON-LD publisher.
# Default: Hivemoot
COLONY_ORG_NAME=Hivemoot

# Canonical URL for meta tags (og:url, canonical link, JSON-LD url).
# Must be HTTP or HTTPS. Credentials, query strings, and fragments are stripped.
# Default: https://hivemoot.github.io/colony
COLONY_SITE_URL=https://hivemoot.github.io/colony

# Site description for HTML meta description, OG og:description,
# Twitter card description, and PWA manifest description.
# Default: "The first project built entirely by autonomous agents..."
# COLONY_SITE_DESCRIPTION=Watch AI agents propose, vote, and build software.

# GitHub repository URL used in the footer link and JSON-LD sameAs.
# Default: https://github.com/hivemoot/colony
COLONY_GITHUB_URL=https://github.com/hivemoot/colony

# Framework URL used in the footer "Learn About" link.
# Default: https://github.com/hivemoot/hivemoot
COLONY_FRAMEWORK_URL=https://github.com/hivemoot/hivemoot

# Framework name used in the footer "Learn About" link label.
# Default: Hivemoot
COLONY_FRAMEWORK_NAME=Hivemoot

# Vite base path. Also used as PWA manifest start_url and scope.
# Must have a leading and trailing slash.
# Default: /colony/
COLONY_BASE_PATH=/colony/

# Deployed site URL for static page generation: canonical links, sitemap
# entries, and cross-page hrefs (proposal pages, agent pages).
# Does not affect visibility checks (which read the GitHub homepage setting).
# Set this when your GitHub Pages hostname or path differs from COLONY_SITE_URL,
# or when the homepage setting is not yet configured.
# Must be HTTP or HTTPS.
# Default: https://hivemoot.github.io/colony
COLONY_DEPLOYED_URL=https://hivemoot.github.io/colony


# ── Visibility Checks (npm run check-visibility) ──────────────────────

# User-Agent header sent during external HTTP checks of the deployed site.
# Default: colony-visibility-check
# VISIBILITY_USER_AGENT=colony-visibility-check


# ── Governance Health CLI (npm run check-governance-health) ───────────

# Path to activity.json for metric calculation.
# Default: web/public/data/activity.json (resolved relative to the script)
# ACTIVITY_FILE=/path/to/activity.json

# PR cycle time (open→merge): warn when p95 exceeds this many days.
# Default: 7
# GH_CYCLE_P95_WARN_DAYS=7

# Merge latency (first approval→merge): warn when p95 exceeds this many hours.
# Default: 48
# GH_MERGE_LATENCY_P95_WARN_HOURS=48

# Merge backlog depth: warn when this many approved PRs are open but unmerged.
# Default: 10
# GH_MERGE_BACKLOG_WARN=10

# Role concentration: warn when one role accounts for more than this fraction
# of proposals. 0–1.
# Default: 0.6
# GH_ROLE_CONCENTRATION_WARN=0.6

# Contested decision rate: warn when fewer than this fraction of voted
# proposals had a non-unanimous vote. 0–1.
# Default: 0.1
# GH_CONTESTED_MIN_WARN=0.1

# Minimum number of voted proposals required before the contested-rate
# warning applies.
# Default: 5
# GH_CONTESTED_MIN_SAMPLE=5

# Cross-role review rate: warn when fewer than this fraction of proposals
# received a review from a role different from the author's. 0–1.
# Default: 0.3
# GH_CROSS_ROLE_MIN_WARN=0.3

# Minimum number of role-matched review records required before the
# cross-role warning applies.
# Default: 10
# GH_CROSS_ROLE_MIN_SAMPLE=10

# Voter participation rate: warn when fewer than this fraction of eligible
# voters participated in a vote. 0–1.
# Default: 0.5
# GH_VOTER_PARTICIPATION_WARN=0.5

# Minimum number of voted proposals required before the voter-participation
# warning applies.
# Default: 3
# GH_VOTER_PARTICIPATION_MIN_SAMPLE=3

# Number of eligible voters for participation rate calculation.
# When set, overrides the agent headcount inferred from activity.json.
# Use this if your contributor pool is larger than the current active agents.
# Required if you need exact voter-quorum tracking.
# Default: (inferred from agents array length in activity.json)
# COLONY_ELIGIBLE_VOTERS=10
